# Typio Wayland frontend configuration example
#
# Location: $XDG_CONFIG_HOME/typio/wayland.toml
#          (defaults to ~/.config/typio/wayland.toml)
#
# This file owns popup styling for the Wayland frontend. Framework-level
# settings (engine selection, shortcuts, voice runtime) live in core.toml
# next to it.

[display]
# Theme: "auto" (follow desktop), "light", or "dark"  (default: "auto")
popup_theme = "auto"

# Candidate layout: "horizontal" or "vertical"  (default: "vertical")
candidate_layout = "vertical"

# Popup font size in points, range 6–72  (default: 11)
font_size = 11

# Font family for the popup  (default: "Sans")
# font_family = "Noto Sans CJK SC"

# Show engine mode label (e.g. "中" / "A") in popup  (default: false)
# popup_mode_indicator = false

# ── Custom color schemas ─────────────────────────────────────────────
# Define per-channel overrides for the light and/or dark variants.
# Custom values take priority over the built-in palette for that variant.
# The active variant is chosen by popup_theme (or desktop detection for "auto").
# Use 6-digit hex (#rrggbb) or 8-digit hex (#rrggbbaa) with alpha.
# Omit any key to keep the built-in default for that channel.

# [display.colors.light]
# background     = "#f8f9fa"
# border         = "#ced4da"
# text           = "#212529"
# muted          = "#868e96"   # candidate index numbers and mode label
# preedit        = "#495057"
# selection      = "#339af0f5"
# selection_text = "#ffffff"
# status         = "#ef4444"   # voice recording / processing indicator

# [display.colors.dark]
# background     = "#141414"
# border         = "#2a2a2a"
# text           = "#e8e8e8"
# muted          = "#666666"
# preedit        = "#aaaaaa"
# selection      = "#1971c2f5"
# selection_text = "#ffffff"
# status         = "#ef4444"   # voice recording / processing indicator
